#!/usr/bin/env python3

import argparse
import ipaddress
import json
import re
import sys
from pathlib import Path
from urllib.parse import urlparse, parse_qs

TEXT_EXTENSIONS = {
    ".md",
    ".txt",
    ".json",
    ".yaml",
    ".yml",
    ".toml",
    ".py",
    ".sh",
    ".js",
    ".jsx",
    ".ts",
    ".tsx",
    ".html",
    ".css",
}

URL_RE = re.compile(r"(?P<url>(?:https?|file|data|javascript)://[^\s<>'\")]+|javascript:[^\s<>'\")]+)", re.IGNORECASE)
SHORTENER_HOSTS = {"bit.ly", "tinyurl.com", "t.co", "goo.gl", "ow.ly", "is.gd", "buff.ly", "cutt.ly"}
PASTE_HOST_KEYWORDS = ("pastebin", "hastebin", "rentry.co", "controlc.com", "privatebin")
RAW_HOSTS = {"raw.githubusercontent.com", "gist.githubusercontent.com"}
SECRET_QUERY_KEYS = {"token", "access_token", "api_key", "apikey", "key", "secret", "password", "auth", "credential"}


def iter_files(root: Path):
    if root.is_file():
        yield root
        return
    for path in root.rglob("*"):
        if path.is_file():
            yield path


def should_scan(path: Path) -> bool:
    return path.suffix.lower() in TEXT_EXTENSIONS or path.name in {"SKILL.md", "README.md"}


def load_text(path: Path):
    raw = path.read_bytes()
    if b"\x00" in raw:
        return None
    try:
        return raw.decode("utf-8")
    except UnicodeDecodeError:
        return raw.decode("utf-8", errors="replace")


def host_is_private(hostname: str) -> bool:
    if hostname in {"localhost", "ip6-localhost"}:
        return True
    try:
        address = ipaddress.ip_address(hostname)
    except ValueError:
        return False
    return address.is_private or address.is_loopback or address.is_link_local


def classify(url: str):
    parsed = urlparse(url)
    scheme = parsed.scheme.lower()
    hostname = (parsed.hostname or "").lower()
    findings = []

    if scheme in {"file", "data", "javascript"}:
        findings.append(("unsafe_scheme", "high"))
    if parsed.username or parsed.password:
        findings.append(("credentialed_url", "high"))
    if hostname and host_is_private(hostname):
        findings.append(("local_or_private_host", "high"))
    if hostname in SHORTENER_HOSTS:
        findings.append(("url_shortener", "medium"))
    if hostname in RAW_HOSTS:
        findings.append(("raw_code_host", "medium"))
    if any(keyword in hostname for keyword in PASTE_HOST_KEYWORDS):
        findings.append(("paste_site", "medium"))

    query = parse_qs(parsed.query, keep_blank_values=True)
    for key in query:
        if key.lower() in SECRET_QUERY_KEYS:
            findings.append(("sensitive_query_parameter", "high"))
            break

    return findings


def scan_file(path: Path):
    text = load_text(path)
    if text is None:
        return []

    findings = []
    for line_no, line in enumerate(text.splitlines(), start=1):
        for match in URL_RE.finditer(line):
            url = match.group("url").rstrip(".,;]")
            for kind, severity in classify(url):
                findings.append(
                    {
                        "path": str(path),
                        "line": line_no,
                        "kind": kind,
                        "severity": severity,
                        "url": url,
                    }
                )
    return findings


def main():
    parser = argparse.ArgumentParser(description="Scan skill files for risky URLs.")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
    parser.add_argument("paths", nargs="+", help="Files or directories to scan")
    args = parser.parse_args()

    roots = [Path(path).expanduser().resolve() for path in args.paths]
    files = []
    for root in roots:
        if not root.exists():
            print(f"missing: {root}", file=sys.stderr)
            return 2
        for path in iter_files(root):
            if should_scan(path):
                files.append(path)

    unique_files = sorted(set(files))
    findings = []
    for path in unique_files:
        findings.extend(scan_file(path))

    result = {
        "scanner": "urls",
        "scanned_files": len(unique_files),
        "findings": findings,
        "status": "clean" if not findings else "review",
    }

    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(f"scanned_files={result['scanned_files']}")
        print(f"findings={len(findings)}")
        print(f"status={result['status']}")
        for finding in findings:
            print(
                f"{finding['severity']} {finding['kind']} "
                f"{finding['path']}:{finding['line']} :: {finding['url']}"
            )

    return 0 if not findings else 1


if __name__ == "__main__":
    raise SystemExit(main())
